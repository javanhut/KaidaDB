#!/usr/bin/env bash
# kaidadb-ctl — portable daemon manager for KaidaDB
# Works on any POSIX-compatible Linux without requiring a specific init system.
set -euo pipefail

INSTALL_DIR="@@INSTALL_DIR@@"
CONFIG_DIR="@@CONFIG_DIR@@"
DATA_DIR="@@DATA_DIR@@"

PIDFILE="${XDG_RUNTIME_DIR:-/tmp}/kaidadb.pid"
LOGFILE="${XDG_STATE_HOME:-$HOME/.local/state}/kaidadb/kaidadb.log"

get_pid() {
    if [[ -f "$PIDFILE" ]]; then
        local pid
        pid=$(<"$PIDFILE")
        if kill -0 "$pid" 2>/dev/null; then
            echo "$pid"
            return 0
        fi
        rm -f "$PIDFILE"
    fi
    return 1
}

cmd_start() {
    if pid=$(get_pid); then
        echo "KaidaDB is already running (PID $pid)"
        return 0
    fi

    mkdir -p "$(dirname "$LOGFILE")"

    echo "Starting KaidaDB..."
    cd "$DATA_DIR"
    nohup "$INSTALL_DIR/kaidadb-server" \
        --config "$CONFIG_DIR/config.toml" \
        >> "$LOGFILE" 2>&1 &
    echo $! > "$PIDFILE"
    echo "KaidaDB started (PID $!)"
    echo "Logs: $LOGFILE"
}

cmd_stop() {
    if pid=$(get_pid); then
        echo "Stopping KaidaDB (PID $pid)..."
        kill "$pid"
        # Wait up to 10 seconds for graceful shutdown
        for i in $(seq 1 10); do
            if ! kill -0 "$pid" 2>/dev/null; then
                rm -f "$PIDFILE"
                echo "KaidaDB stopped"
                return 0
            fi
            sleep 1
        done
        echo "Forcefully killing KaidaDB..."
        kill -9 "$pid" 2>/dev/null || true
        rm -f "$PIDFILE"
        echo "KaidaDB killed"
    else
        echo "KaidaDB is not running"
    fi
}

cmd_restart() {
    cmd_stop
    cmd_start
}

cmd_status() {
    if pid=$(get_pid); then
        echo "KaidaDB is running (PID $pid)"
        echo "Logs: $LOGFILE"
    else
        echo "KaidaDB is not running"
        return 1
    fi
}

cmd_logs() {
    if [[ -f "$LOGFILE" ]]; then
        tail -f "$LOGFILE"
    else
        echo "No log file found at $LOGFILE"
        return 1
    fi
}

case "${1:-}" in
    start)   cmd_start   ;;
    stop)    cmd_stop    ;;
    restart) cmd_restart ;;
    status)  cmd_status  ;;
    logs)    cmd_logs    ;;
    *)
        echo "Usage: kaidadb-ctl {start|stop|restart|status|logs}"
        exit 1
        ;;
esac
